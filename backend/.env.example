# Copy to .env and fill in. Never commit .env.
ENVIRONMENT=development
DEBUG=true

# Postgres (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/shimavault

# Twitch API (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:8000/api/v1/auth/twitch

# Embeddings + LLM
OPENAI_API_KEY=
GEMINI_API_KEY=

# Vector store (local dev)
CHROMA_PATH=./chroma

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000
